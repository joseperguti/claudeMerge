#!/usr/bin/env bash
# pre-push hook: doble revisión Claude + Codex
# Verifica que lo que se sube corresponde al commit message declarado.
# Veredictos: APROBADO (continúa), REVISAR (pregunta), BLOQUEADO (cancela).

set -euo pipefail

CLAUDE_BIN="${CLAUDE_BIN:-/Users/josemaria/.local/bin/claude}"
CODEX_BIN="${CODEX_BIN:-$(command -v codex 2>/dev/null || true)}"

extract_verdict() {
  { echo "$1" | grep -oE 'APROBADO|REVISAR|BLOQUEADO' | tail -1; } || true
}

confirm_continue() {
  local msg="$1"
  echo "$msg"
  echo "   ¿Continuar el push? [s/N]"
  read -r answer < /dev/tty
  [[ "$answer" =~ ^[sS]$ ]]
}

run_claude_review() {
  local prompt="$1"
  "$CLAUDE_BIN" --print "$prompt" 2>/dev/null || true
}

run_codex_review() {
  local prompt="$1"
  local out_file
  out_file=$(mktemp)

  if ! printf "%s" "$prompt" | "$CODEX_BIN" exec --sandbox read-only --output-last-message "$out_file" - >/dev/null 2>&1; then
    rm -f "$out_file"
    return 1
  fi

  cat "$out_file"
  rm -f "$out_file"
}

remote="$1"
remote_url="$2"

commits_to_push=""
range=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    base=$(git merge-base HEAD origin/HEAD 2>/dev/null || git rev-list --max-parents=0 HEAD)
    range="$base...$local_sha"
  else
    range="$remote_sha...$local_sha"
  fi
  commits_to_push+=$(git log "$range" --pretty=format:"- %h %s" --no-merges 2>/dev/null)
  commits_to_push+=$'\n'
done

if [[ -z "$(echo "$commits_to_push" | tr -d '[:space:]')" ]]; then
  exit 0
fi

files_changed=$({ git diff --name-status "$range" || true; } 2>/dev/null | head -60)
diff_content=$({ git diff "$range" -- . \
  ':(exclude)package-lock.json' \
  ':(exclude)yarn.lock' \
  ':(exclude)*.lock' || true; } 2>/dev/null | head -c 10000)
last_commit_msg=$(git log -1 --pretty=format:"%s%n%n%b")

BASE_PROMPT="Eres un revisor de código técnico. Verifica que los cambios que se van a subir corresponden exactamente a lo declarado en el commit.

## Tarea declarada (commit message)
$last_commit_msg

## Commits incluidos en el push
$commits_to_push

## Archivos modificados
$files_changed

## Diff del código
\`\`\`diff
$diff_content
\`\`\`

---

Responde con este formato exacto:

### ✅ Cambios que corresponden
(lista breve)

### ⚠️ Cambios no declarados o dudosos
(lista breve, o «ninguno»)

### ❌ Discrepancias o riesgos
(lista breve, o «ninguno»)

### 📋 Veredicto
Escribe UNA de estas tres palabras exactas en la última línea, sola, sin nada más:
APROBADO
REVISAR
BLOQUEADO

Criterio:
- APROBADO: los cambios son fieles a la tarea
- REVISAR: hay cambios menores no declarados pero no críticos
- BLOQUEADO: cambios fuera de scope o discrepancias graves"

echo ""
echo "🤖  Claude revisando el push..."
echo ""

if [[ ! -x "$CLAUDE_BIN" ]]; then
  if confirm_continue "⚠️  Claude CLI no está disponible en '$CLAUDE_BIN'."; then
    exit 0
  fi
  exit 1
fi

claude_report=$(run_claude_review "$BASE_PROMPT")
if [[ -z "$claude_report" ]]; then
  if confirm_continue "⚠️  No se pudo obtener informe de Claude."; then
    exit 0
  fi
  exit 1
fi

claude_verdict=$(extract_verdict "$claude_report")

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "### Claude"
echo "$claude_report"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [[ -z "$CODEX_BIN" ]]; then
  if confirm_continue "⚠️  Codex CLI no está disponible en PATH."; then
    case "$claude_verdict" in
      APROBADO) exit 0 ;;
      REVISAR) confirm_continue "⚠️  REVISAR de Claude." && exit 0 || exit 1 ;;
      BLOQUEADO) echo "❌  BLOQUEADO por Claude."; exit 1 ;;
      *) exit 1 ;;
    esac
  fi
  exit 1
fi

echo "🤖  Codex auditando el informe de Claude..."
echo ""

CODEX_PROMPT="Eres un segundo revisor técnico. Debes auditar tanto el diff como el informe previo de Claude para validar su calidad y detectar omisiones.

## Tarea declarada (commit message)
$last_commit_msg

## Commits incluidos en el push
$commits_to_push

## Archivos modificados
$files_changed

## Diff del código
\`\`\`diff
$diff_content
\`\`\`

## Informe previo de Claude
$claude_report

---

Valida explícitamente si el informe de Claude es correcto o si omitió algo.

Responde con este formato exacto:

### ✅ Coincidencias correctas (incluyendo validación de Claude)
### ⚠️ Omisiones o dudas detectadas (incluyendo posibles fallos del informe de Claude)
### ❌ Riesgos o discrepancias graves
### 📋 Veredicto
Última línea: APROBADO o REVISAR o BLOQUEADO"

codex_report=$(run_codex_review "$CODEX_PROMPT" || true)
if [[ -z "$codex_report" ]]; then
  if confirm_continue "⚠️  No se pudo obtener informe de Codex."; then
    case "$claude_verdict" in
      APROBADO) exit 0 ;;
      REVISAR) confirm_continue "⚠️  REVISAR de Claude." && exit 0 || exit 1 ;;
      BLOQUEADO) echo "❌  BLOQUEADO por Claude."; exit 1 ;;
      *) exit 1 ;;
    esac
  fi
  exit 1
fi

codex_verdict=$(extract_verdict "$codex_report")

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "### Codex"
echo "$codex_report"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [[ "$claude_verdict" == "BLOQUEADO" || "$codex_verdict" == "BLOQUEADO" ]]; then
  echo "❌  BLOQUEADO — Push cancelado por revisión AI."
  echo "   Usa 'git push --no-verify' para saltarte la revisión puntualmente."
  exit 1
fi

if [[ "$claude_verdict" == "REVISAR" || "$codex_verdict" == "REVISAR" ]]; then
  if confirm_continue "⚠️  REVISAR — Alguno de los revisores detectó cambios dudosos."; then
    exit 0
  fi
  exit 1
fi

if [[ "$claude_verdict" == "APROBADO" && "$codex_verdict" == "APROBADO" ]]; then
  echo "✅  APROBADO por Claude y Codex — Push continuando."
  exit 0
fi

if confirm_continue "⚠️  Veredicto no claro de alguno de los revisores."; then
  exit 0
fi
exit 1
